# LLM provider — Gemini API key
API_LLM=your-gemini-api-key-here
LLM_MODEL=gemini-3.1-flash-lite

# Kokoro TTS (optional — falls back to ~/.config/kokoro-runtime/env)
KOKORO_MODEL=${HOME}/.local/share/kokoro/kokoro-v1.0.onnx
KOKORO_VOICES=${HOME}/.local/share/kokoro/voices-v1.0.bin
KOKORO_VOICE_DEFAULT=am_fenrir
KOKORO_LANGUAGE=es
KOKORO_SPEED=1.0
